<!DOCTYPE html>
<html lang="th">
<%- include('layout/head') %>

    <body class="text-slate-800 antialiased min-h-screen">

        <%- include('layout/navbar', { activePage: 'admin_users' , user: locals.user }) %>

            <main class="main-content px-4 sm:px-6 lg:px-8 py-8 w-full">

                <div class="flex flex-col md:flex-row justify-between md:items-center mb-8 gap-4">
                    <div>
                        <h1 class="text-2xl font-bold text-slate-900">จัดการบัญชีผู้ใช้</h1>
                        <p class="text-sm text-slate-500 mt-1">เพิ่มระบบผู้ใช้และสิทธิ์การเข้าถึง WMS</p>
                    </div>

                    <a href="/manage-users"
                        class="bg-emerald-600 text-white px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-emerald-700 shadow-sm shadow-emerald-600/20 transition-all flex items-center focus:outline-none shrink-0 w-fit">
                        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z">
                            </path>
                        </svg>
                        สร้างบัญชีผู้ใช้ใหม่
                    </a>
                </div>

                <div class="bg-white shadow-sm border border-slate-200 rounded-xl overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr
                                    class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500 font-semibold">
                                    <th class="px-6 py-4">ID</th>
                                    <th class="px-6 py-4">ชื่อผู้ใช้</th>
                                    <th class="px-6 py-4">บทบาท</th>
                                    <th class="px-6 py-4 text-center">จัดการ</th>
                                </tr>
                            </thead>
                            <tbody id="userTableBody" class="divide-y divide-slate-100">
                                <tr>
                                    <td colspan="4" class="px-6 py-4 text-center text-slate-500 text-sm">กำลังโหลด...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </main>

            <script src="/js/main.js"></script>
            <script>
                const AUTH_USER = { username: "<%= locals.user ? locals.user.username : '' %>", role: "<%= locals.user ? locals.user.role : '' %>" };

                document.addEventListener('DOMContentLoaded', () => {
                    const tableBody = document.getElementById('userTableBody');
                    const currentUser = AUTH_USER.username;

                    fetchUsers();

                    async function fetchUsers() {
                        try {
                            const res = await fetch('/api/admin/users');
                            const users = await res.json();
                            renderUsers(users);
                        } catch (e) {
                            tableBody.innerHTML = `<tr><td colspan="4" class="px-6 py-4 text-center text-rose-500">โหลดข้อมูลล้มเหลว</td></tr>`;
                        }
                    }

                    function renderUsers(users) {
                        tableBody.innerHTML = '';
                        users.forEach(u => {
                            const tr = document.createElement('tr');
                            tr.className = "hover:bg-slate-50 transition-colors";

                            const roleBadge = u.role === 'manager'
                                ? '<span class="px-2.5 py-1 rounded bg-indigo-100 text-indigo-800 text-xs font-semibold">ผู้จัดการ</span>'
                                : '<span class="px-2.5 py-1 rounded bg-slate-100 text-slate-700 text-xs font-semibold">ผู้ปฏิบัติงาน</span>';

                            const canDelete = u.username !== currentUser;
                            const deleteBtn = canDelete
                                ? `<button onclick="deleteUser(${u.id}, '${u.username}')" class="text-rose-500 hover:bg-rose-50 p-2 rounded-lg transition-colors"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg></button>`
                                : `<span class="text-xs text-slate-400">บัญชีนี้ (ตัวคุณ)</span>`;

                            tr.innerHTML = `
                        <td class="px-6 py-4 text-sm text-slate-500 font-mono">${u.id}</td>
                        <td class="px-6 py-4 font-medium text-slate-800">${u.username}</td>
                        <td class="px-6 py-4">${roleBadge}</td>
                        <td class="px-6 py-4 text-center">${deleteBtn}</td>
                    `;
                            tableBody.appendChild(tr);
                        });
                    }

                    // Delete Logic
                    window.deleteUser = async (id, username) => {
                        const conf = await Swal.fire({
                            title: 'ยืนยันการลบผู้ใช้?',
                            text: `ต้องการลบผู้ใช้ "${username}" ใช่หรือไม่`,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#059669',
                            cancelButtonColor: '#ef4444',
                            confirmButtonText: 'ยืนยันลบ',
                            cancelButtonText: 'ยกเลิก'
                        });

                        if (conf.isConfirmed) {
                            try {
                                const res = await fetch(`/api/admin/users/${id}`, { method: 'DELETE' });
                                if (res.ok) {
                                    fetchUsers();
                                    Swal.fire('ลบสำเร็จ!', '', 'success');
                                } else {
                                    const data = await res.json();
                                    Swal.fire('ลบล้มเหลว', data.error, 'error');
                                }
                            } catch (e) {
                                Swal.fire('ข้อผิดพลาด', 'ระบบขัดข้อง', 'error');
                            }
                        }
                    };
                });
            </script>
    </body>

</html>