<!-- Sidebar Navigation Component -->
<aside id="sidebar" class="sidebar">
    <div class="sidebar-inner">

        <!-- Logo / Brand -->
        <div class="px-5 pt-6 pb-4">
            <div class="flex items-center gap-2.5">
                <div
                    class="w-8 h-8 rounded-xl bg-gradient-to-br from-emerald-400 to-teal-500 flex items-center justify-center shadow-md shadow-emerald-500/30">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-bold text-slate-800 leading-tight">Fresh WMS</p>
                    <p class="text-[9px] font-semibold text-slate-400 tracking-widest leading-tight uppercase">Warehouse
                    </p>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 px-3 space-y-0.5 pb-4">
            <p class="px-2 mb-2 text-[9px] font-bold text-slate-400 uppercase tracking-widest">Main Menu</p>
            <a href="/" class="sidebar-link <%= locals.activePage === 'dashboard' ? 'active' : '' %>">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z">
                    </path>
                </svg>
                <span>คลังสินค้า</span>
            </a>

            <a href="/add-stock" class="sidebar-link <%= locals.activePage === 'add' ? 'active' : '' %>">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                <span>เพิ่มสต็อก</span>
            </a>

            <a href="/withdraw" class="sidebar-link <%= locals.activePage === 'withdraw' ? 'active' : '' %>">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4m7-7l-7 7 7 7">
                    </path>
                </svg>
                <span>เบิกสินค้า</span>
            </a>

            <a href="/history" class="sidebar-link <%= locals.activePage === 'history' ? 'active' : '' %>">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>ประวัติ</span>
            </a>

            <% if (user && user.role==='manager' ) { %>
                <div class="pt-4">
                    <p class="px-2 mb-2 text-[9px] font-bold text-slate-400 uppercase tracking-widest">Admin</p>

                    <a href="/admin" class="sidebar-link <%= locals.activePage === 'admin' ? 'active' : '' %>">
                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z">
                            </path>
                        </svg>
                        <span>แดชบอร์ด</span>
                    </a>

                    <!-- จัดการสินค้า always-open sub-menu -->
                    <div>
                        <div class="flex items-center gap-2 px-2 py-1.5 mt-1 mb-1">
                            <svg class="w-4 h-4 flex-shrink-0 text-slate-400" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                            </svg>
                            <span class="text-xs font-semibold text-slate-500">จัดการสินค้า</span>
                        </div>
                        <div class="ml-3 space-y-0.5 border-l-2 border-slate-100 pl-2">
                            <a href="/manage-products?tab=add"
                                class="sidebar-link py-2 text-xs <%= locals.activePage === 'manage_products_add' ? 'active' : '' %>">
                                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M12 4v16m8-8H4" />
                                </svg>
                                เพิ่มสินค้าใหม่
                            </a>
                            <a href="/manage-products?tab=edit"
                                class="sidebar-link py-2 text-xs <%= locals.activePage === 'manage_products_edit' ? 'active' : '' %>">
                                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                แก้ไขสินค้า
                            </a>
                            <a href="/manage-products?tab=delete"
                                class="sidebar-link py-2 text-xs <%= locals.activePage === 'manage_products_delete' ? 'active' : '' %>">
                                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                                ลบสินค้า
                            </a>
                        </div>
                    </div>


                    <a href="/manage-users"
                        class="sidebar-link <%= locals.activePage === 'manage_users' ? 'active' : '' %>">
                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z">
                            </path>
                        </svg>
                        <span>จัดการผู้ใช้</span>
                    </a>
                </div>
                <% } %>
        </nav>

        <!-- User Footer -->
        <div class="mx-3 mb-4 p-3 rounded-xl bg-slate-50 border border-slate-100">
            <div class="flex items-center gap-2.5 mb-2.5">
                <div
                    class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-400 to-teal-500 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                    <%= user ? user.username.charAt(0).toUpperCase() : '?' %>
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-semibold text-slate-700 truncate leading-tight">
                        <%= user ? user.username : 'Guest' %>
                    </p>
                    <p class="text-[10px] text-slate-400 font-medium">
                        <%= user && user.role==='manager' ? 'Manager' : 'Staff' %>
                    </p>
                </div>
            </div>
            <form action="/logout" method="POST">
                <button type="submit"
                    class="flex items-center gap-2 w-full px-3 py-1.5 rounded-lg text-xs font-semibold text-rose-500 hover:bg-rose-50 hover:text-rose-600 transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1">
                        </path>
                    </svg>
                    ออกจากระบบ
                </button>
            </form>
        </div>
    </div>
</aside>

<!-- Mobile toggle -->
<button id="sidebarToggle"
    class="fixed top-4 left-4 z-50 lg:hidden bg-white p-2 rounded-xl shadow-md border border-slate-200 text-slate-500 hover:bg-emerald-50 hover:text-emerald-600 transition-colors">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
</button>
<div id="sidebarOverlay" class="sidebar-overlay hidden"></div>

<script>
    (function () {
        var toggle = document.getElementById('sidebarToggle');
        var sidebar = document.getElementById('sidebar');
        var overlay = document.getElementById('sidebarOverlay');
        if (toggle && sidebar && overlay) {
            toggle.addEventListener('click', function () {
                sidebar.classList.toggle('open');
                overlay.classList.toggle('hidden');
            });
            overlay.addEventListener('click', function () {
                sidebar.classList.remove('open');
                overlay.classList.add('hidden');
            });
        }
    })();
</script>